generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Book {
  id          String   @id @default(cuid())
  title       String
  genre       String
  targetWords Int
  content     String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
