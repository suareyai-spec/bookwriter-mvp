generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String?
  passwordHash      String
  createdAt         DateTime  @default(now())
  books             Book[]
  credits           BookCredit[]
  stripeCustomerId  String?
  subscriptionId    String?
  subscriptionPlan  String?
  subscriptionStatus String?
  monthlyBooksUsed  Int       @default(0)
  monthlyResetDate  DateTime?
  isGenerating      Boolean   @default(false)
  generationStartedAt DateTime?
  revisionCount     Int       @default(0)
  revisionResetDate DateTime?
  monthlyNewslettersUsed Int  @default(0)
  monthlyArticlesUsed    Int  @default(0)
  freeBookUsed           Boolean @default(false)
  freeRevisionsUsed      Int     @default(0)
  freeTranslationsUsed   Int     @default(0)
  freeNewslettersUsed    Int     @default(0)
  freeArticlesUsed       Int     @default(0)
  teamMembers TeamMember[] @relation("TeamMembers")
  ownedTeam   TeamMember[] @relation("TeamOwner")
  apiCosts    ApiCost[]
}

model TeamMember {
  id        String   @id @default(cuid())
  teamOwner String
  email     String
  userId    String?
  role      String   @default("member")
  createdAt DateTime @default(now())
  user      User?    @relation("TeamMembers", fields: [userId], references: [id])
  owner     User     @relation("TeamOwner", fields: [teamOwner], references: [id])
}

model Book {
  id             String          @id @default(cuid())
  title          String
  description    String
  genre          String?
  tone           String?
  audience       String?
  language       String?
  bookLength     String?
  status         String          @default("complete")
  progress       String?
  seriesId       String?
  seriesOrder    Int?
  contentType    String          @default("book")
  mature         Boolean         @default(false)
  humanize       Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  userId         String
  currentChapter Int             @default(0)
  totalChapters  Int             @default(0)
  storyBible     String?         @db.Text
  outline        String?         @db.Text
  user           User            @relation(fields: [userId], references: [id])
  versions       BookVersion[]
  references     BookReference[]
  chapters       Chapter[]
}

model Chapter {
  id        String   @id @default(cuid())
  bookId    String
  number    Int
  title     String
  content   String   @db.Text
  wordCount Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, number])
}

model BookReference {
  id        String   @id @default(cuid())
  name      String
  type      String
  content   String
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model BookVersion {
  id        String   @id @default(cuid())
  version   Int      @default(1)
  content   String
  wordCount Int?
  notes     String?
  createdAt DateTime @default(now())
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model ApiCost {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  type         String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  cost         Float
  model        String   @default("claude-opus-4-20250514")
  bookId       String?
  createdAt    DateTime @default(now())
}

model BookCredit {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  bookSize        String
  used            Boolean   @default(false)
  purchasedAt     DateTime  @default(now())
  usedAt          DateTime?
  stripePaymentId String?
}

model Affiliate {
  id                String   @id @default(cuid())
  code              String   @unique
  ownerName         String
  ownerEmail        String
  commissionPercent Int      @default(20)
  totalClicks       Int      @default(0)
  totalConversions  Int      @default(0)
  totalEarned       Float    @default(0)
  payoutStatus      String   @default("unpaid")
  isActive          Boolean  @default(false)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  conversions       AffiliateConversion[]
}

model AffiliateConversion {
  id              String    @id @default(cuid())
  affiliateId     String
  userEmail       String?
  stripeSessionId String?
  plan            String?
  amountUsd       Float
  commissionUsd   Float
  createdAt       DateTime  @default(now())
  affiliate       Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
}
