<!-- Controls -->
<div class="controls" id="controls"></div>
<div class="slide-counter" id="counter"></div>
<button class="fs-btn" id="fsBtn" title="Press F for fullscreen">Fullscreen (F)</button>

<script>
(function(){
const slides=document.querySelectorAll('.slide');
const total=slides.length;
let current=0;
const controls=document.getElementById('controls');
const counter=document.getElementById('counter');

// Create dots
for(let i=0;i<total;i++){
const d=document.createElement('button');
d.className='dot'+(i===0?' active':'');
d.addEventListener('click',()=>go(i));
controls.appendChild(d);
}
const dots=controls.querySelectorAll('.dot');

function go(n){
if(n<0||n>=total)return;
slides[current].classList.remove('active');
dots[current].classList.remove('active');
current=n;
slides[current].classList.add('active');
dots[current].classList.add('active');
counter.textContent=(current+1)+' / '+total;
}
go(0);

document.addEventListener('keydown',function(e){
if(e.key==='ArrowRight'||e.key==='ArrowDown')go(current+1);
else if(e.key==='ArrowLeft'||e.key==='ArrowUp')go(current-1);
else if(e.key==='f'||e.key==='F'){
if(!document.fullscreenElement)document.documentElement.requestFullscreen();
else document.exitFullscreen();
}else if(e.key==='Escape'&&document.fullscreenElement){
document.exitFullscreen();
}
});

document.getElementById('fsBtn').addEventListener('click',function(){
if(!document.fullscreenElement)document.documentElement.requestFullscreen();
else document.exitFullscreen();
});

// Touch/swipe
let tx=0;
document.addEventListener('touchstart',e=>{tx=e.touches[0].clientX});
document.addEventListener('touchend',e=>{
const dx=e.changedTouches[0].clientX-tx;
if(Math.abs(dx)>50){dx<0?go(current+1):go(current-1)}
});
})();
</script>
</body>
</html>
