const PDFDocument = require('pdfkit');
const fs = require('fs');

const doc = new PDFDocument({ size: [1280, 720], margin: 0 });
doc.pipe(fs.createWriteStream('KOSIQ-Investor-Pitch-2026.pdf'));

const blue = '#26acf7';
const dark = '#1d1d1f';
const gray = '#6e6e73';
const green = '#34c759';
const lightGray = '#f5f5f7';
const red = '#ff3b30';
const amber = '#f59e0b';
const purple = '#8b5cf6';

function newSlide(bg = '#ffffff') {
  doc.addPage({ size: [1280, 720], margin: 0 });
  doc.rect(0, 0, 1280, 720).fill(bg);
}

function sectionTag(text, y = 60) {
  doc.fontSize(12).font('Helvetica').fillColor(blue).text(text.toUpperCase(), 80, y, { width: 1120 });
}

function title(text, y = 85) {
  doc.fontSize(32).font('Helvetica-Bold').fillColor(dark).text(text, 80, y, { width: 1120 });
}

function subtitle(text, y) {
  doc.fontSize(14).font('Helvetica').fillColor(gray).text(text, 80, y, { width: 1120 });
}

function body(text, x, y, opts = {}) {
  doc.fontSize(opts.size || 13).font(opts.bold ? 'Helvetica-Bold' : 'Helvetica').fillColor(opts.color || gray).text(text, x, y, { width: opts.width || 500, lineGap: 3 });
}

function card(x, y, w, h, borderColor) {
  doc.roundedRect(x, y, w, h, 8).fillAndStroke(lightGray, borderColor || '#e5e7eb');
}

function metricBox(x, y, num, label) {
  doc.roundedRect(x, y, 160, 70, 8).fill(lightGray);
  doc.fontSize(24).font('Helvetica-Bold').fillColor(blue).text(num, x, y + 12, { width: 160, align: 'center' });
  doc.fontSize(11).font('Helvetica').fillColor(gray).text(label, x, y + 45, { width: 160, align: 'center' });
}

// ===== SLIDE 0: TITLE =====
doc.rect(0, 0, 1280, 720).fill('#000');
doc.fontSize(14).font('Helvetica').fillColor('#999').text('INVESTOR PRESENTATION — 2026', 80, 200, { width: 1120 });
doc.fontSize(52).font('Helvetica-Bold').fillColor('#fff').text('KOSIQ', 80, 240);
doc.fontSize(22).font('Helvetica').fillColor('#ccc').text('AI-Powered Medical Economics Platform', 80, 310);
doc.fontSize(14).fillColor('#888').text('Transforming Healthcare Analytics with Artificial Intelligence', 80, 350);
doc.fontSize(12).fillColor('#666').text('David Suarez, CTO  •  Dr. JD Suarez, CMO', 80, 620);
doc.fontSize(12).fillColor('#666').text('david@iamdivid.com  •  drjdsuarez@gmail.com', 80, 640);

// ===== SLIDE 1: PROBLEM =====
newSlide();
sectionTag('The Problem');
title('Healthcare Groups Are Flying Blind');
body('Managed care organizations handle millions of patients and billions in claims — yet most rely on outdated reporting tools that show what already happened.', 80, 150, { size: 15, width: 1100 });

const problems = [
  ['Retrospective Only', 'Legacy platforms report on past events. By the time you see the data, the patient is already in the ER.'],
  ['No AI, No Predictions', 'Current tools lack predictive analytics. CMOs can\'t identify at-risk patients before costly events.'],
  ['Fragmented Data', 'Claims, EHR, pharmacy, and lab data live in separate silos with no unified view.'],
  ['Manual Workflows', 'Clinicians spend hours pulling reports, cross-referencing data, and building spreadsheets.']
];

problems.forEach((p, i) => {
  const y = 220 + i * 105;
  doc.roundedRect(80, y, 1120, 90, 8).fill(lightGray);
  doc.fontSize(15).font('Helvetica-Bold').fillColor(dark).text(p[0], 100, y + 15, { width: 300 });
  doc.fontSize(12).font('Helvetica').fillColor(gray).text(p[1], 100, y + 40, { width: 1060 });
});

// ===== SLIDE 2: SOLUTION =====
newSlide();
sectionTag('The Solution');
title('KOSIQ — Intelligence, Not Just Analytics');
body('KOSIQ is an AI-powered medical economics platform that ingests claims data, predicts outcomes, and tells clinicians exactly what to do — in plain English.', 80, 150, { size: 15, width: 1100 });

const solutions = [
  [blue, 'Predictive Analytics', '30/60/90-day hospitalization risk, LACE readmission scoring, cost forecasting'],
  [green, 'AI Recommendations', 'Monthly reports with prioritized actions, financial impact, and patient lists'],
  [purple, 'Natural Language Chat', 'Ask questions about your data in plain English — "Show me diabetics with HbA1c > 9"'],
  [amber, 'Clinical Alert Programs', '8 CMO-designed protocols for high-risk identification (SMI, HIV, ESRD, CKD, etc.)']
];

solutions.forEach((s, i) => {
