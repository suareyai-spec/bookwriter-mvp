  doc.roundedRect(80, y, 1120, 90, 8).lineWidth(1).fillAndStroke('#fff', '#e5e7eb');
  doc.rect(80, y, 5, 90).fill(s[0]);
  doc.fontSize(15).font('Helvetica-Bold').fillColor(dark).text(s[1], 105, y + 15, { width: 300 });
  doc.fontSize(12).font('Helvetica').fillColor(gray).text(s[2], 105, y + 40, { width: 1060 });
});

