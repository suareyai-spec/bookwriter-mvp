plotghost.ai {
    encode zstd gzip
    header /_next/static/* Cache-Control "public, max-age=31536000, immutable"
    header /favicon.svg Cache-Control "public, max-age=86400"
    header /logo.svg Cache-Control "public, max-age=86400"
    header /og-image.png Cache-Control "public, max-age=86400"
    reverse_proxy localhost:3000 {
        flush_interval -1
        transport http {
            read_timeout 600s
            write_timeout 600s
        }
    }
}

www.plotghost.ai {
    redir https://plotghost.ai{uri} permanent
}

api.narevo.ai {
    encode zstd gzip
    reverse_proxy localhost:3002
}

